{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main Medusa Agent App window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:event:default",
    "core:tray:default",
    "shell:default",
    "shell:allow-open",
    "opener:default",
    "opener:allow-open-url",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:scope-home-recursive",
    "dialog:default",
    "notification:default",
    "notification:allow-notify",
    "process:default",
    "autostart:default",
    "updater:default"
  ]
}
