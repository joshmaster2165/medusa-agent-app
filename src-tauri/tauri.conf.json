{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Medusa",
  "version": "1.5.2",
  "identifier": "com.medusasec.agent.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Medusa",
        "width": 980,
        "height": 700,
        "minWidth": 820,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 18 },
        "visible": false
      }
    ],
    "macOSPrivateApi": false,
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "Medusa — endpoint security for MCP"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Endpoint security agent for MCP",
    "longDescription": "Medusa is an endpoint security agent for Model Context Protocol (MCP) infrastructure. This app is the control panel for the headless medusa-agent daemon: monitor traffic, configure DLP policy, and manage your local installation.",
    "copyright": "© 2026 Medusa Security",
    "publisher": "Medusa Security",
    "homepage": "https://medusasec.com",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "exceptionDomain": "medusasec.com",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://medusasec.com/api/app/updates/{{target}}/{{current_version}}"
      ],
      "pubkey": ""
    }
  }
}
